{
  "app": "npx ts-node --prefer-ts-exts bin/specter.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "node_modules"]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-ecs:arnFormatIncludesClusterName": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,

    "region": "ap-south-1",

    "ecrRepoName": "specter-web",
    "ecsClusterName": "specter-prod",
    "ecsServiceName": "specter-web",
    "s3BucketName": "specter-screenshots-prod",
    "secretName": "specter/prod",

    "taskCpu": 1024,
    "taskMemory": 3072,
    "minTasks": 1,
    "maxTasks": 4,

    "domain": "",
    "subdomain": ""
  }
}
